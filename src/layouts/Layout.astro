---
// Self-hosted fonts (bundled at build — no external requests, no layout shift).
// Latin subset only, to keep the deploy lean.
import '@fontsource/cormorant-garamond/latin-400.css';
import '@fontsource/cormorant-garamond/latin-500.css';
import '@fontsource/cormorant-garamond/latin-600.css';
import '@fontsource/eb-garamond/latin-400.css';
import '@fontsource/eb-garamond/latin-500.css';
import '@fontsource/eb-garamond/latin-400-italic.css';

import '../styles/global.css';

// Preload the two most-used Latin faces (body 400 + display 500) so the web
// fonts arrive promptly; combined with the metric-matched fallbacks in
// global.css, the swap from fallback to web font is then shift-free.
import ebGaramondBody from '@fontsource/eb-garamond/files/eb-garamond-latin-400-normal.woff2?url';
import cormorantDisplay from '@fontsource/cormorant-garamond/files/cormorant-garamond-latin-500-normal.woff2?url';

import Sidebar from '../components/Sidebar.astro';
import BaseSchema from '../components/BaseSchema.astro';
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.description } = Astro.props;
const pageTitle = title ? `${title} — ${site.name}` : site.title;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
const ogImage = Astro.site ? new URL('/og.jpg', Astro.site).href : '/og.jpg';
// Footer copyright year (fixed at build time — a rebuild refreshes it).
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={ebGaramondBody} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={cormorantDisplay} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      // Apply the saved (or system) theme before paint to avoid a flash. Manual
      // choice is persisted in localStorage by the toggle in the sidebar.
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.dataset.theme = 'dark';
          } else if (t === 'light') {
            document.documentElement.dataset.theme = 'light';
          }
        } catch (e) {}
      })();
    </script>
    <style is:inline>
      /* Critical CSS, inlined so it applies at parse time — before the bundled
         stylesheet finishes loading. The browser's first paint then already
         matches the final layout. Without it, the page briefly painted with
         user-agent defaults (an 8px body margin; the lightbox overlay shown)
         and snapped to these values once the stylesheet arrived, which surfaced
         as the html>body and #lightbox>figure Cumulative Layout Shift (CLS).
         `.lightbox` keeps the same selector as global.css so the more specific
         `.lightbox.is-open` rule still wins when the viewer opens. */
      body {
        margin: 0;
      }
      .lightbox {
        display: none;
      }
    </style>
    <link rel="icon" href="/favicon.png" type="image/png" sizes="256x256" />
    <link rel="icon" href="/favicon-dark.png" type="image/png" sizes="256x256" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={site.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="generator" content={Astro.generator} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <BaseSchema />
  </head>
  <body>
    <Sidebar />
    <main class="main">
      <slot />
      <footer class="site-footer">
        <p class="site-footer__line">
          <span>© {year} {site.name}</span>
          <a class="site-footer__link" href="/privacy">Privacy</a>
          <a class="site-footer__link" href="/license">Licensing</a>
          <span class="site-footer__views" hidden>Page Viewed <span class="site-footer__views-count"></span></span>
        </p>
      </footer>
    </main>
    <script>
      // Deter casual saving/dragging of photos site-wide (a deterrent, not DRM).
      const guard = (e: Event) => {
        const t = e.target as HTMLElement | null;
        if (t && t.closest('.photo-tile, .lightbox')) e.preventDefault();
      };
      document.addEventListener('contextmenu', guard);
      document.addEventListener('dragstart', guard);
    </script>
    <script>
      // First-party page-view counter: register this page's view and show the
      // total. Stays hidden on any error, so the footer never shows a broken state.
      (() => {
        const el = document.querySelector<HTMLElement>('.site-footer__views');
        if (!el) return;
        const out = el.querySelector<HTMLElement>('.site-footer__views-count');
        const path = location.pathname.replace(/\/+$/, '') || '/';
        fetch('/api/views', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ path }),
        })
          .then((r) => (r.ok ? r.json() : null))
          .then((d) => {
            if (!d || d.count == null) return;
            if (out) out.textContent = Number(d.count).toLocaleString();
            el.hidden = false;
          })
          .catch(() => {});
      })();
    </script>
  </body>
</html>
