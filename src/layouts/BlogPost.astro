---
import Layout from './Layout.astro';
import ShareButton from '../components/ShareButton.astro';
import Lightbox from '../components/Lightbox.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  cover?: ImageMetadata;
  coverAlt?: string;
  readingTime?: number;
  section: { label: string; href: string };
}
const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  cover,
  coverAlt = '',
  readingTime,
  section,
} = Astro.props;

const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const iso = (d: Date) => new Date(d).toISOString().slice(0, 10);
---

<Layout title={title} description={description}>
  <article class="post page">
    <p class="post__eyebrow"><a href={section.href}>{section.label}</a></p>
    <h1 class="post__title">{title}</h1>

    <div class="post__meta">
      <time datetime={iso(pubDate)}>{fmt(pubDate)}</time>
      {readingTime && <span>{readingTime} min read</span>}
    </div>

    {
      cover && (
        <figure class="post__cover">
          <Image
            src={cover}
            alt={coverAlt}
            widths={[640, 960, 1280, 1600]}
            sizes="(min-width: 1024px) 760px, 100vw"
          />
        </figure>
      )
    }

    <div class="prose post__body">
      <slot />
    </div>

    <footer class="post__footer">
      <ShareButton title={title} />
      {
        tags.length > 0 && (
          <ul class="post__tags" aria-label="Tags">
            {tags.map((t) => (
              <li class="tag">{t}</li>
            ))}
          </ul>
        )
      }
      {updatedDate && <p class="post__updated">Updated {fmt(updatedDate)}</p>}
    </footer>

    {/*
      ── Comments ──────────────────────────────────────────────────────────────
      Left as a deliberate placeholder. See the README ("Comments — free options")
      for a comparison of Giscus, utterances, Cusdis, and a same-origin approach.
      To wire one up, drop its embed here, e.g.:

        <section class="comments" aria-label="Comments">
          <!-- provider embed / <div id="..."> goes here -->
        </section>

      and allow its domain(s) in the CSP (security.csp in astro.config.mjs).
    */}
  </article>

  {/* Full-screen viewer for any <Photo>/<Gallery> tiles in the post body. */}
  <Lightbox />
</Layout>
