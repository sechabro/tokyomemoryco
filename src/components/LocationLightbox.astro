---
// Shared full-screen photo viewer. Wires up every `.photo-tile` button on the
// page (each carries data-full, data-alt, and optional data-caption).
---

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" aria-hidden="true">
  <button class="lightbox__close" type="button" aria-label="Close viewer">&times;</button>
  <button class="lightbox__nav lightbox__prev" type="button" aria-label="Previous photo">&#8249;</button>
  <figure class="lightbox__figure">
    <img class="lightbox__img" alt="" draggable="false" />
        <!-- <figcaption class="lightbox__caption" hidden></figcaption> -->

        <div class="lightbox__details">
          <p class="lightbox__description"></p>
          <a 
            href="#" 
            class="lightbox__book-btn" 
            target="_blank" 
            rel="noopener noreferrer"
          >
          </a>
        </div>
  </figure>
  <button class="lightbox__nav lightbox__next" type="button" aria-label="Next photo">&#8250;</button>
</div>

<style is:global>
  .lightbox__figure {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* 2. Float the details container directly on top of the image */
  .lightbox__details {
    position: absolute;
    bottom: 15%; /* Positions the text card beautifully over the lower portion of the frame */
    left: 50%;
    transform: translateX(-50%);
    
    /* Presentation styles */
    width: 90%;
    max-width: 500px;
    padding: 1.5rem;
    text-align: center;
    z-index: 100; /* Forces it above the image render stack */
    
    /* Sleek frosted glass background so the text is crisp over light/dark photos */
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }

  /* Your clean, high-readability neighborhood description text */
  .lightbox__description {
    color: #e5e7eb; /* Soft off-white to cut glare on dark overlay */
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* The clean monochrome Book Now button */
  .lightbox__book-btn {
    display: inline-block;
    background-color: #ffffff;
    color: #000000;
    padding: 0.75rem 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border-radius: 2px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
</style>

<script>
  const lightbox = document.getElementById('lightbox');
  const tiles = Array.from(document.querySelectorAll<HTMLButtonElement>('.photo-tile'));

  if (lightbox && tiles.length) {
    const image = lightbox.querySelector('.lightbox__img') as HTMLImageElement;
    //const caption = lightbox.querySelector('.lightbox__caption') as HTMLElement;

    const description = lightbox.querySelector('.lightbox__description') as HTMLElement;
    const bookBtn = lightbox.querySelector('.lightbox__book-btn') as HTMLAnchorElement;

    const btnClose = lightbox.querySelector('.lightbox__close') as HTMLButtonElement;
    const btnPrev = lightbox.querySelector('.lightbox__prev') as HTMLButtonElement;
    const btnNext = lightbox.querySelector('.lightbox__next') as HTMLButtonElement;
    let index = -1;
    let shown = -1; // which photo the <img> currently holds
    let seq = 0; // invalidates an in-flight upgrade when the photo changes

    const render = (i: number) => {
      index = (i + tiles.length) % tiles.length;
      const tile = tiles[index];
      image.alt = tile.dataset.alt ?? '';

      // 1. Maintain standard title/caption behavior (Location text)
      const cap = tile.dataset.caption ?? '';
      //caption.textContent = cap;
      //caption.hidden = cap === '';
      
      // 2. Extract and mount the custom neighborhood description text
      const descText = tile.dataset.description ?? '';
      if (description) {
        description.textContent = descText;
        description.hidden = descText === '';
      }
      
      // 3. Keep booking button hidden unless a location description is active
      const bookingUrl = tile.dataset.link ?? '#';
      if (bookBtn) {
        bookBtn.href = bookingUrl;

        // Conditional text handling for the "You Choose" flexible edge case
        if (cap.toLowerCase() === 'you choose') {
          bookBtn.textContent = 'Book a custom shoot!';
        } else {
          bookBtn.textContent = cap ? `Book a shoot in ${cap}` : 'Book a shoot in this location';
        }

        // Keep the button hidden if no link or description text is present
        bookBtn.hidden = descText === '' || bookingUrl === '#';
      }

      if (shown === index) return; 
      shown = index;
      const ticket = ++seq;

      // Show the rendition the grid already downloaded — it's in cache, so the
      // photo appears immediately instead of waiting for the big lightbox
      // file. The browser keeps painting the previous photo until a new file
      // arrives, so the <img> also stays hidden (is-loading) until this
      // preview's load event — otherwise opening photo B after photo A would
      // flash A first.
      const thumb = tile.querySelector<HTMLImageElement>('.photo__img');
      const preview = thumb?.currentSrc || '';
      const full = tile.dataset.full ?? '';
      image.classList.add('is-loading');
      image.removeAttribute('sizes');
      image.srcset = '';
      image.src = preview || full;

      // Then upgrade in place to a viewport-matched rendition: with srcset +
      // sizes the browser fetches only as many pixels as the screen needs
      // (data-full, the largest rendition, remains the fallback). Decoded
      // off-screen first so the swap never blanks the visible photo.
      const srcset = thumb?.srcset ?? '';
      if (!srcset || preview === full) return;
      const hi = new Image();
      hi.sizes = '100vw';
      hi.srcset = srcset;
      hi.src = full;
      const apply = () => {
        if (ticket !== seq) return; // user has moved to another photo
        image.sizes = '100vw';
        image.srcset = srcset;
        image.src = full;
      };
      if (hi.decode) hi.decode().then(apply).catch(() => {});
      else hi.onload = apply;
    };

    const reveal = () => image.classList.remove('is-loading');
    image.addEventListener('load', reveal);
    image.addEventListener('error', reveal);

    const open = (i: number) => {
      render(i);
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      btnClose.focus();
    };

    const close = () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (index > -1) tiles[index].focus();
    };

    tiles.forEach((tile, i) => tile.addEventListener('click', () => open(i)));
    btnClose.addEventListener('click', close);
    btnPrev.addEventListener('click', () => render(index - 1));
    btnNext.addEventListener('click', () => render(index + 1));
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') render(index - 1);
      else if (e.key === 'ArrowRight') render(index + 1);
    });
  }
</script>
