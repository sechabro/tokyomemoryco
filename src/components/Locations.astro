---
import type { ImageMetadata } from 'astro';
import { renderPhoto, GRID_SIZES } from '../lib/photos';
import Lightbox from './LocationLightbox.astro';
import { location } from '../data/locations';
import { site as siteInfo } from '../config';

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/locations/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}',
  { eager: true }
);
const byName = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(images)) {
  byName.set(path.split('/').pop()!, mod.default);
}

const MONTHS = [
  'January', 'February', 'March', 'April', 'May', 'June',
  'July', 'August', 'September', 'October', 'November', 'December',
];

// Evaluated at build time: show every calendar photo we have, newest first.
const items = await Promise.all(
  location
    .filter((e) => byName.has(e.file)) // only entries whose image is present
    // Newest first; same-month ties sort Z→A by location ("a…" below "z…").
    //.sort((a, b) => b.year - a.year || b.month - a.month || b.location.localeCompare(a.location))
    .sort((a, b) => a.location.localeCompare(b.location))
    .map(async (e) => {
      const photo = await renderPhoto(byName.get(e.file)!);
      return {
        ...photo,
        label: `${e.location}`,
        location: e.location,
        description: e.description,
        bookLink: e.book_link
      };
    })
);

// Structured data: each month as an ImageObject with its date and place.
const base = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: `Locations — ${siteInfo.name}`,
  url: `${base}${Astro.url.pathname}`,
  isPartOf: { '@id': `${base}/#website` },
  author: { '@id': `${base}/#person` },
  image: items.map((it) => ({
    '@type': 'ImageObject',
    contentUrl: `${base}${it.full}`,
    name: it.label,
    caption: it.label,
    dateCreated: `${it.year}-${String(it.month).padStart(2, '0')}`,
    contentLocation: { '@type': 'Place', name: it.location },
    creator: { '@id': `${base}/#person` },
    copyrightHolder: { '@id': `${base}/#person` },
    creditText: siteInfo.name,
    copyrightNotice: `© ${siteInfo.name}`,
    license: `${base}/license`,
    acquireLicensePage: `${base}/contact`,
  })),
};
---

{
  items.length === 0 ? (
    <p class="empty">
      No location photos yet. Add entries in <code>src/data/locations.ts</code> and images in
      <code>src/assets/locations/</code>.
    </p>
  ) : (
    <section class="calendar-grid" aria-label="Location photographs">
      {items.map((item, i) => (
        <figure class="calendar-item">
          <button
            class="photo-tile"
            type="button"
            aria-label={`${item.label} — view larger`}
            data-full={item.full}
            data-alt={item.label}
            data-caption={item.label}
            data-description={item.description}
            data-link={item.bookLink}
          >
            <img
              class="photo__img"
              src={item.src}
              srcset={item.srcset}
              sizes={GRID_SIZES}
              alt={item.label}
              loading={i < 4 ? 'eager' : 'lazy'}
              decoding="async"
              draggable={false}
            />
            <div class="photo-tile__overlay">
          <figcaption class="calendar-caption">{item.label}</figcaption>
            </div>
          </button>
          
        </figure>
      ))}
    </section>
  )
}

<Lightbox />

<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

<style>
  .calendar-item {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  .photo-tile {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    overflow: hidden;
  }

  .photo__img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Keep the slick movement on hover without changing image exposure */
  .photo-tile:hover .photo__img {
    transform: scale(1.04);
  }

  /* Clear transparent overlay layer centered vertically and horizontally */
  .photo-tile__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;     /* Centers vertically */
    justify-content: center;  /* Centers horizontally */
    padding: 1.5rem;
    background: transparent;  /* Removed the dimming gradient entirely */
  }

  /* Large, bold, perfectly centered typography */
  .calendar-caption {
    font-family: var(--serif-display, serif);
    font-size: 3.5rem; /* Noticeably scaled up for premium editorial impact */
    font-weight: 700;
    color: #ffffff;
    text-align: center;
    margin: 0;
    
    /* High-fidelity legibility protector against light backgrounds */
    text-shadow: 
      0px 1px 2px rgba(0, 0, 0, 0.7),    /* Tight rim anchor */
      0px 3px 6px rgba(0, 0, 0, 0.5),    /* Soft downward drop */
      0px 0px 15px rgba(0, 0, 0, 0.4),   /* Radial ambient glow (Left/Right safety) */
      0px -2px 8px rgba(0, 0, 0, 0.35);
      
    transition: transform 0.3s ease;
  }

  /* Interactive pop state when hovered */
  .photo-tile:hover .calendar-caption {
    transform: scale(1.05);
  }

  /* Mobile responsiveness scaling overrides */
  @media (max-width: 640px) {
    .calendar-caption {
      font-size: 1.5rem; /* Scales down gracefully on smaller screens */
    }
  }
</style>