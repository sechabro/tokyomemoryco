---
// Site-wide JSON-LD: identifies the site and the photographer so search engines
// and AI answer engines can understand who/what this is. Gallery pages add their
// own ImageGallery / ImageObject graphs.
import { site, social } from '../config';

const base = Astro.site ? Astro.site.href.replace(/\/$/, '') : '';

const graph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${base}/#website`,
      url: `${base}/`,
      name: site.title,
      description: site.description,
      inLanguage: 'en',
      publisher: { '@id': `${base}/#person` },
    },
    {
      '@type': 'Person',
      '@id': `${base}/#person`,
      name: site.name,
      url: `${base}/`,
      jobTitle: 'Photographer',
      sameAs: [social.instagram, social.linkedin, social.github],
    },
  ],
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} />
