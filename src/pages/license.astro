---
import Layout from "../layouts/Layout.astro";
import { site, social } from "../config";
---

<Layout
    title="Image licensing"
    description="Licensing and usage terms for the photographs on this site — every photograph is by the site owner, all rights reserved."
>
    <article class="page prose">
        <h1 class="page__title">Image licensing</h1>

        <p class="lede">
            Every photograph on this site was made by me, {site.name}{site.nameZh && (
                <> (<span class="name-zh">{site.nameZh}</span>)</>
            )} — I shoot all of them myself. © {site.name}. All rights reserved.
        </p>

        <p>
            You're welcome to view the images here. They are not licensed for
            reuse, redistribution, or modification, and they may not be used to
            train machine-learning models.
        </p>

        <p>
            <strong
                >No commercial use is permitted without my prior written
                permission.</strong
            > To license a photograph, or to use one for any commercial purpose, please
            contact me first — I'm glad to discuss it.
        </p>

        <p>
            Get in touch with me, {site.name}, on
            <a
                href={social.instagram}
                target="_blank"
                rel="noopener noreferrer">Instagram</a
            > or
            <a
                href={social.linkedin}
                target="_blank"
                rel="noopener noreferrer">LinkedIn</a
            >, or through the <a href="/contact">contact page</a>.
        </p>
    </article>
</Layout>
