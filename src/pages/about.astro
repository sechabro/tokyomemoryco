---
import Layout from "../layouts/Layout.astro";
import { site, social } from "../config";

// ── Edit everything below to tell your own story. ───────────────────────────
// The little "fact" cards are just example fields — rename them, add more, or
// remove the whole block if you prefer plain prose.
const facts = [
    { label: "Locations", line: "We shoot three locations weekly:", muted: "Shibuya, Shinjuku, Asakusa" },
    { label: "Offerings", line: "1-2 hour photo sessions, day or night", muted: "Individual or group. Max 4 people" },
    { label: "Additional Services", line: "Custom locations, color grading", muted: "You can pick any location within Tokyo's 23 wards for an additional fee. We also offer color grading services." },
];
---

<Layout
    title="About"
    description={`About ${site.name} — Tokyo Street Portrait Photography.`}
>
    <article class="page prose">
        <h1 class="page__title">About</h1>

        <p class="lede">
            Your Tokyo story deserves more than a selfie stick. Welcome to 
            <strong>Tokyo Memory Co.</strong>, where we turn your 
            journey through Tokyo into beautiful, professional street portraits.
        </p>

        <p>
            Tokyo is vibrant neon one moment, cinematic and hazy the next. As we
            explore some of the city's most iconic corners together, we combine 
            the artistry of professional street photography with the speed of 
            today's digital age.
        </p>

        <p>
            The best part? No waiting weeks for a download link. We just focus on 
            capturing you at your absolute best, <em>in-camera</em>. Just scan a 
            personalized QR code at the end of your session and download your 
            high-resolution gallery immediately.
        </p>

        <div class="facts">
            {
                facts.map((f) => (
                    <section class="fact">
                        <h2 class="fact__label">{f.label}</h2>
                        <p class="fact__line">{f.line}</p>
                        <p class="fact__muted">{f.muted}</p>
                    </section>
                ))
            }
        </div>
        
        <!--
        <p>
            <a
                class="text-link"
                href={social.github}
                target="_blank"
                rel="noopener noreferrer"
            >
                Find me elsewhere →
            </a>
        </p>
        -->
    </article>
</Layout>
