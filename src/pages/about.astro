---
import Layout from "../layouts/Layout.astro";
import { site, social } from "../config";

// ── Edit everything below to tell your own story. ───────────────────────────
// The little "fact" cards are just example fields — rename them, add more, or
// remove the whole block if you prefer plain prose.
const facts = [
    { label: "Currently", line: "Photographer & writer", muted: "Your City, Country" },
    { label: "Shooting", line: "Digital & 35mm film", muted: "Landscapes, travel, the everyday" },
    { label: "Since", line: "20XX", muted: "Always learning" },
];
---

<Layout
    title="About"
    description={`About ${site.name} — photographer and writer.`}
>
    <article class="page prose">
        <h1 class="page__title">About</h1>

        <p class="lede">
            I'm {site.name} — a photographer and writer, and the person behind
            the pictures on this site.
        </p>

        <p>
            This is placeholder copy from the template. Write a few short
            paragraphs about yourself here: where you're based, what draws you to
            photography, the cameras or film you like, and what you tend to point
            a lens at. Keep it personal and brief — a paragraph or three is
            plenty.
        </p>

        <p>
            Photography is how I slow down and pay attention — to light, weather,
            and the quiet shape of a place. The galleries here gather what I've
            seen along the way.
        </p>

        <p>
            I write here, too: a <a href="/blog/tech">Tech Blog</a> for notes on
            tools and building for the web, and a
            <a href="/blog/photography">Photo Blog</a> of field notes on light,
            places, and the craft of photography.
        </p>

        <div class="facts">
            {
                facts.map((f) => (
                    <section class="fact">
                        <h2 class="fact__label">{f.label}</h2>
                        <p class="fact__line">{f.line}</p>
                        <p class="fact__muted">{f.muted}</p>
                    </section>
                ))
            }
        </div>

        <p>
            <a
                class="text-link"
                href={social.github}
                target="_blank"
                rel="noopener noreferrer"
            >
                Find me elsewhere →
            </a>
        </p>
    </article>
</Layout>
